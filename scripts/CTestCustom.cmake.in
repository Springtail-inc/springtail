# Set the project source directory
set(PROJECT_SOURCE_DIR "@PROJECT_SOURCE_DIR@")

# Define the paths to system.json configs
set(SYSTEM_JSON_TEST "${PROJECT_SOURCE_DIR}/system.json.test")
set(SYSTEM_JSON_SETTINGS "${PROJECT_SOURCE_DIR}/system.json.settings")

# Check if system.json.test exists
if(NOT EXISTS "${SYSTEM_JSON_TEST}")
    message(STATUS "system.json.test does not exist. Copying system.json.settings to system.json.test...")
    execute_process(COMMAND cp "${SYSTEM_JSON_SETTINGS}" "${SYSTEM_JSON_TEST}")
else()
    message(STATUS "system.json.test already exists.")
endif()

set(ENV{SPRINGTAIL_PROPERTIES_FILE} ${SYSTEM_JSON_TEST})
