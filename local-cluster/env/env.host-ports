# Local cluster host ports configuration
# The ports we expose on the host machine for accessing services running in the local cluster.
# These are not required if you are not accessing services from outside the cluster.
# Primary database port
HOST_PORT_PRIMARY_DB=15432
# Redis server port
HOST_PORT_REDIS=16379
# Proxy server port
HOST_PORT_PROXY=55432
# FDW Postgres service port
HOST_PORT_FDW=45432
# For AWS mock service
HOST_PORT_MOTO=29999