#!/bin/bash
# Builds a package off the current code base and store it under the given $OUTPUT_DIR.
# This runs in a building container, so we assume all the build deps are present.
ci_workspace="${CI_WORKSPACE:-/__w/springtail/springtail}"
set -e
set -o pipefail
cd $ci_workspace
# Mark the mounted repository as safe (container user differs from host owner)
git config --global --add safe.directory "$ci_workspace"
./debug.sh
cd debug
make install
cd "$ci_workspace"
./package.sh
n=$(ls -t releases | head -n 1)
mv "releases/$n" "$OUTPUT_DIR/"

# Fix ownership so host user can access the output
if [ -n "${HOST_UID:-}" ] && [ -n "${HOST_GID:-}" ]; then
  chown -R "$HOST_UID:$HOST_GID" "$OUTPUT_DIR"
fi