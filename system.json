{
    "logging" : {
        "log_level" : "debug",
        "log_path" : "/tmp/springtail.log",
        "log_file_size" : 1000000,
        "log_file_count" : 10,
        "log_pattern": "[%Y-%m-%d %T.%e %z] [%^%l%$] [%s:%#:%!] [thread %t] %v"
    },
    "iopool" : {
        "threads" : 10,
        "filehandles": 30
    },
    "redis" : {
        "host" : "localhost",
        "port": 6379,
        "user": "default",
        "password": null,
        "db": 0,
        "keep_alive_secs": 30,
        "pool" : {
            "connections" : 10,
            "max_idle_secs": 300,
            "max_connection_lifetime_secs": 0
        }
    },
    "write_cache": {
        "server" : {
            "port" : 55051,
            "worker_threads": 8,
            "io_threads": 1
        },
        "client": {
            "connections": 8,
            "server" : "localhost"
        }
    },
    "xid_mgr": {
        "server" : {
            "port" : 55052,
            "worker_threads": 8,
            "base_path": "/tmp/xid_mgr"
        },
        "client": {
            "connections": 8,
            "server" : "localhost"
        }
    },
    "storage": {
	"table_dir": "/tmp/springtail/table"
    }
}
